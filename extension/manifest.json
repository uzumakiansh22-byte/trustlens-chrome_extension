{
  "manifest_version": 3,
  "name": "TrustLens Pro: Forensic AI",
  "version": "2.0.0",
  "description": "Advanced AI-powered creator credibility and image forensics analyzer.",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_title": "Open TrustLens Dashboard"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
